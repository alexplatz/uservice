{
  "name": "uservice",
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "private": true,
  "scripts": {
    "build": "bun run --cwd apps/client build",
    "proxy": "caddy run",
    "dev:client": "bun run --cwd apps/client dev",
    "watch:client": "bun run --cwd apps/client watch",
    "watch:server": "bun run --cwd apps/server watch",
    "watch:db": "bun run --cwd apps/db watch",
    "watch": "concurrently 'bun run watch:client' 'bun run watch:server' 'bun run watch:db'",
    "start:client": "bun run --cwd apps/client start",
    "start:server": "bun run --cwd apps/server start",
    "start:db": "bun run --cwd apps/db start",
    "start": "concurrently 'bun run start:client' 'bun run start:server' 'bun run start:db'"
  },
  "workspaces": [
    "apps/*"
  ]
}
