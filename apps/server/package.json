{
  "name": "server",
  "dependencies": {
    "@elysiajs/bearer": "^1.4.3",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/jwt": "^1.4.0",
    "@logtape/logtape": "^2.0.5",
    "@passwordless-id/webauthn": "^2.3.5",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.25",
    "elysia-rate-limit": "^4.6.0",
    "google-auth-library": "^10.6.2"
  },
  "devDependencies": {
    "@bogeychan/elysia-logger": "^0.1.10",
    "@types/bun": "^1.3.9"
  },
  "scripts": {
    "watch": "bun --hot src/index.ts",
    "build": "bun build --compile --minify-whitespace --minify-syntax --target bun --outfile server  src/index.ts",
    "dev": "bun src/index.ts"
  },
  "prettier": {
    "tabWidth": 2,
    "printWidth": 128,
    "semi": false,
    "singleQuote": true,
    "jsxSingleQuote": true,
    "bracketSameLine": true,
    "arrowParens": "avoid"
  }
}
